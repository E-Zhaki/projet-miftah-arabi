<!DOCTYPE html>
<html lang="fr" data-bs-theme="auto">

	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<meta name="description" content="{% block description %}{% endblock %}">
		<meta name="author" content="Miftah Arabi">
		<meta name="published" content="DWWM">
		<meta name="theme-color" content="#c49b66">

		<title>{% block title %}{% endblock %} · Espace admin</title>

		{# WebpakEncore stylesheets #}
		{% block stylesheets %}
			{{ encore_entry_link_tags('app') }}
		{% endblock %}

		{# WebpakEncore javascripts #}
		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}

		{% block j_query %}{% endblock %}

		{% block data_tables %}{% endblock %}

		{% block select2 %}{% endblock %}

        {# Font Awesone #}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer">

		{# Favicon #}
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96">
		<link rel="icon" type="image/svg+xml" href="/favicon.svg">
		<link rel="shortcut icon" href="/favicon.ico">
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<meta name="apple-mobile-web-app-title" content="MyWebSite">
		<link rel="manifest" href="/site.webmanifest">

        {# Custom StyleSheet #}
		<style>
			.bi {
				display: inline-block;
				width: 1rem;
				height: 1rem;
				vertical-align: -0.125em;
				fill: currentColor;
			}

			/* Sidebar */
			@media(min-width: 768px) {
				.sidebar .offcanvas-lg {
					position: sticky;
					top: 48px;
				}
			}

			.sidebar .nav-link {
				font-size: 0.875rem;
				font-weight: 500;
				color: #4a3728;
			}

			.sidebar .nav-link:hover {
				color: #8c6a43;
			}

			.sidebar .nav-link.active {
				color: #c49b66;
				font-weight: 600;
			}

			.sidebar-heading {
				font-size: 0.75rem;
			}

			/* Navbar */
			.navbar-brand {
				padding-top: 0.75rem;
				padding-bottom: 0.75rem;
				background-color: #8c6a43;
				box-shadow: inset -1px 0 0 rgba(0, 0, 0, 0.25);
				color: #fff !important;
			}

			header.navbar {
				background-color: #2f241b !important;
				border-bottom: 2px solid #c49b66;
			}
		</style>
	</head>
	<body>
		<header class="navbar sticky-top bg-dark flex-md-nowrap p-0 shadow" data-bs-theme="dark">
			<a class="navbar-brand col-md-3 col-lg-2 me-0 px-3 fs-6 text-white" href="{{path('app_admin_home')}}">MA</a>
			<ul class="navbar-nav flex-row d-md-none">
				<li class="nav-item text-nowrap">
					<button class="nav-link px-3 text-white" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
						<i class="fa-solid fa-bars"></i>
					</button>
				</li>
			</ul>
		</header>
        <div class="container-fluid">
            <div class="row">
                <div class="sidebar border border-right col-md-3 col-lg-2 p-0" style="background-color: #faf6f0;">
                    <div class="offcanvas-md offcanvas-end" style="background-color: #faf6f0;" tabindex="-1" id="sidebarMenu" aria-labelledby="sidebarMenuLabel">
                        <div class="offcanvas-header">
                            <h5 class="offcanvas-title" id="sidebarMenuLabel">MA</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#sidebarMenu" aria-label="Close"></button>
                        </div>
                        <div class="offcanvas-body d-md-flex flex-column p-0 pt-lg-3 overflow-y-auto">
                            <ul class="nav flex-column">
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" aria-current="page" href="{{path('app_admin_home')}}">
                                        <i class="fa-solid fa-house"></i>
                                        Tableau de bord
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{path('app_admin_category_index')}}">
                                        <i class="fa-solid fa-folder"></i>
                                        Catégories
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{path('app_admin_lesson_index')}}">
                                        <i class="fa-solid fa-feather"></i>
                                        Leçons
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{path('app_admin_tag_index')}}">
                                        <i class="fa-solid fa-hashtag"></i>
                                        Tags
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{ path('app_admin_resource_index') }}">
                                        <i class="fa-solid fa-link"></i>
                                        Ressources
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{path('app_admin_contact_index')}}">
                                        <i class="fa-solid fa-address-book"></i>
                                        Contacts
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{path('app_admin_user_index')}}">
                                        <i class="fa-solid fa-users"></i>
                                        Utilisateurs
                                    </a>
                                </li>
                            </ul>

                            <hr class="my-3">

                            <ul class="nav flex-column mb-auto">
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{path('app_admin_profile_index')}}">
                                        <i class="fa-solid fa-user"></i>
                                        Mon profil
                                    </a>
                                </li>
                            </ul>
                            <hr class="my-3">

                            <ul class="nav flex-column mb-auto">
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{path('app_user_home')}}">
                                    <i class="fa-solid fa-outdent"></i>
                                        Espace utilisateur
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{path('app_visitor_welcome')}}">
                                    <i class="fa-solid fa-rotate-left"></i>
                                        Retour au site
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link d-flex align-items-center gap-2" href="{{path('app_logout')}}">
                                    <i class="fa-solid fa-right-from-bracket"></i>
                                        Déconnexion
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                    {% block main %}{% endblock %}
                </main>
            </div>
        </div>
	</body>
</html>
