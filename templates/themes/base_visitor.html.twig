<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}{% endblock %} - Miftah Arabi</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        {# SEO #}
        <meta name="robots" content="index, follow">
        <meta name="description" content="{% block description %}{% endblock %}">
        <meta name="keywords" content="{% block keywords %}{% endblock %}">
        <meta name="author" content="Zhaki El Ouarroudi">
        <meta name="publisher" content="Miftah Arabi">
        <meta name="theme-color" content="#cbcbb1">

        {# Favicon #}
        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="shortcut icon" href="/favicon.ico">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="manifest" href="/site.webmanifest">

        {# Font Awesome #}
        {% block font_awesome %}{% endblock %}

        {# Google Fonts #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

        {# Webpack Encore stylesheets #}
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {# Webpack Encore javascripts #}
        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}

        {% block knp_paginator %}{% endblock %}
        {% block j_query %}{% endblock %}
        {% block javascripts_added %}{% endblock %}
    </head>

    <body class="ma-body">

        {% set clientPathInfo = app.request.pathInfo %}

        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_visitor_welcome') }}">
                    MA
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Ouvrir le menu de navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav align-items-lg-center">
                        <li class="nav-item">
                            <a
                                class="nav-link {{ clientPathInfo == path('app_visitor_welcome') ? 'active' : '' }}"
                                {{ clientPathInfo == path('app_visitor_welcome') ? 'aria-current="page"' : '' }}
                                href="{{ path('app_visitor_welcome') }}"
                            >
                                Accueil
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_visitor_welcome') }}#about-me">
                                À propos
                            </a>
                        </li>

                        <li class="nav-item">
                            <a
                                class="nav-link {{ clientPathInfo == path('app_visitor_lesson_index') ? 'active' : '' }}"
                                {{ clientPathInfo == path('app_visitor_lesson_index') ? 'aria-current="page"' : '' }}
                                href="{{ path('app_visitor_lesson_index') }}"
                            >
                                Leçons
                            </a>
                        </li>

                        <li class="nav-item">
                            <a
                                class="nav-link {{ clientPathInfo == path('app_visitor_contact_index') ? 'active' : '' }}"
                                {{ clientPathInfo == path('app_visitor_contact_index') ? 'aria-current="page"' : '' }}
                                href="{{ path('app_visitor_contact_index') }}"
                            >
                                Contact
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        {% if app.user %}
                            {% if is_granted('ROLE_ADMIN') %}
                                <li class="nav-item">
                                    <a class="btn btn-outline-primary mx-lg-2 my-2 my-lg-0" href="{{ path('app_admin_home') }}">
                                        Espace admin
                                    </a>
                                </li>
                            {% endif %}

                            {% if is_granted('ROLE_USER') %}
                                <li class="nav-item">
                                    <a class="btn btn-outline-primary mx-lg-2 my-2 my-lg-0" href="{{ path('app_user_home') }}">
                                        Espace privé
                                    </a>
                                </li>
                            {% endif %}

                            <li class="nav-item">
                                <a class="btn btn-primary mx-lg-2 my-2 my-lg-0" href="{{ path('app_logout') }}">
                                    Déconnexion
                                </a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="btn btn-outline-primary mx-lg-2 my-2 my-lg-0" href="{{ path('app_login') }}">
                                    Connexion
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary mx-lg-2 my-2 my-lg-0" href="{{ path('app_register') }}">
                                    Inscription
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <main>
            {% block main %}{% endblock %}
        </main>

        <footer>
            <div class="container">
                <p class="mb-0 text-center">Miftah Arabi</p>
            </div>
        </footer>
    </body>
</html>