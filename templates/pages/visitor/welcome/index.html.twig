{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Accueil | Miftah Arabi{% endblock %}

{% block description %}
Plateforme d'apprentissage de la langue arabe pour francophones : cours clairs, progressifs et accessibles à tous les niveaux.
{% endblock %}

{% block keywords %}
langue arabe, apprendre l'arabe, arabe littéraire, cours d'arabe, plateforme arabe, Miftah Arabi
{% endblock %}

{% block main %}

    <header class="py-5">
        <div class="container">
            <div class="row">
                <div class="col-md-5 order-md-2 d-flex justify-content-center align-items-center">
                    <img class="img-fluid rounded shadow" src="/images/statics/logomiftah.webp" alt="Illustration de bienvenue Miftah Arabi">
                </div>

                <div class="col-md-7 order-md-1 d-flex flex-column justify-content-center align-items-center align-items-md-start gap-4 text-center text-md-start">
                    <h1 class="mt-4 display-5">Bienvenue sur Miftah Arabi</h1>

                    <div>
                        <p class="lead">La clé pour apprendre l'arabe simplement, pas à pas.</p>
                        <p>
                            Découvrez des leçons claires, progressives et accessibles pour apprendre l'arabe littéraire,
                            enrichir votre vocabulaire et avancer avec méthode.
                        </p>
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-3">
                        <a href="{{ path('app_visitor_lesson_index') }}" class="btn btn-lg btn-primary shadow">
                            Voir les leçons
                        </a>
                        <a href="{{ path('app_visitor_contact_index') }}" class="btn btn-lg btn-outline-primary shadow">
                            Me contacter
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section id="about-me" class="bg-light py-5">
        <h2 class="text-center my-3 display-6">À propos de Miftah Arabi</h2>

        <div class="container">
            <div class="row">
                <div class="col-md-6 d-flex justify-content-center align-items-center">
                    <img class="img-fluid rounded shadow" src="/images/statics/about-miftah-arabi.png" alt="Présentation de Miftah Arabi">
                </div>

                <div class="col-md-6 d-flex flex-column justify-content-center align-items-center align-items-md-start text-center text-md-start">
                    <p>
                        Miftah Arabi est une plateforme pensée pour les francophones qui souhaitent apprendre l'arabe
                        de manière simple, progressive et motivante.
                    </p>
                    <p>
                        Le projet s'adresse aux débutants comme aux apprenants plus avancés, avec des contenus
                        organisés par catégories, niveaux et thématiques.
                    </p>
                    <p>
                        L'objectif est de proposer une approche claire et pédagogique, en s'appuyant sur des leçons,
                        des ressources utiles et des contenus accessibles depuis plusieurs supports.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <h2 class="text-center my-3 display-6">Les dernières leçons</h2>

        <div class="container">
            <div class="row g-4">
                {% for lesson in lessons %}
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow h-100">
                            {% if lesson.image %}
                                <img class="w-100 card-img-top" src="{{ vich_uploader_asset(lesson, 'imageFile') | imagine_filter('visitor_lesson_thumb') }}" alt="{{ lesson.title }}">
                            {% else %}
                                <img class="w-100 card-img-top" src="/images/statics/default-lesson-image.png" alt="{{ lesson.title }}">
                            {% endif %}

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">{{ lesson.title|u.truncate(80, '...') }}</h5>

                                <p class="card-text">
                                    <strong>Catégorie :</strong>
                                    <span class="badge text-bg-info">{{ lesson.category.name }}</span>
                                </p>

                                <p class="card-text">
                                    <strong>Niveau :</strong>
                                    <span class="badge text-bg-warning">
                                        {% if lesson.level == 'debutant' %}
                                            Débutant
                                        {% elseif lesson.level == 'intermediaire' %}
                                            Intermédiaire
                                        {% elseif lesson.level == 'avance' %}
                                            Avancé
                                        {% else %}
                                            {{ lesson.level }}
                                        {% endif %}
                                    </span>
                                </p>

                                {% if lesson.tags is not empty %}
                                    <p class="card-text">
                                        <strong>Tags :</strong>
                                        {% for tag in lesson.tags %}
                                            <span class="badge text-bg-secondary">{{ tag.name }}</span>
                                        {% endfor %}
                                    </p>
                                {% endif %}

                                <p class="card-text">
                                    <small class="text-body-secondary">
                                        Publié le {{ lesson.publishedAt|date('d/m/Y') }}
                                    </small>
                                </p>

                                <div class="mt-auto">
                                    <a href="#" class="btn btn-primary shadow">Lire la leçon</a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <p class="text-center">Aucune leçon publiée pour le moment.</p>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="bg-light py-5">
        <div class="container text-center">
            <h2 class="display-6 mb-3">Une question ?</h2>
            <p class="mb-4">
                Vous pouvez me contacter pour toute question concernant les cours, les ressources
                ou l'apprentissage de l'arabe.
            </p>
            <a href="{{ path('app_visitor_contact_index') }}" class="btn btn-lg btn-primary shadow">
                Contactez-moi
            </a>
        </div>
    </section>

{% endblock %}