{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Accueil | Miftah Arabi{% endblock %}

{% block description %}
Plateforme d'apprentissage de la langue arabe pour francophones : cours clairs, progressifs et accessibles à tous les niveaux.
{% endblock %}

{% block keywords %}
langue arabe, apprendre l'arabe, arabe littéraire, cours d'arabe, plateforme arabe, Miftah Arabi
{% endblock %}

{% block main %}

    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <span class="hero-subtitle">La clé pour apprendre l'arabe</span>
                    <h1 class="hero-title mt-3">Bienvenue sur Miftah Arabi</h1>

                    <p class="hero-text mt-4">
                        Apprenez l'arabe littéraire simplement, étape par étape, grâce à des leçons claires,
                        progressives et accessibles.
                    </p>

                    <p class="hero-text-secondary">
                        Développez votre lecture, votre vocabulaire et votre compréhension avec une approche
                        pédagogique pensée pour les francophones.
                    </p>

                    <div class="d-flex flex-column flex-sm-row gap-3 mt-4">
                        <a href="{{ path('app_visitor_lesson_index') }}" class="btn btn-primary btn-ma">
                            Voir les leçons
                        </a>
                        <a href="{{ path('app_visitor_contact_index') }}" class="btn btn-outline-primary btn-ma-outline">
                            Me contacter
                        </a>
                    </div>
                </div>

                <div class="col-lg-6 text-center">
                    <div class="hero-image-wrapper">
                        <img
                            src="/images/statics/logomiftah.webp"
                            alt="Logo Miftah Arabi"
                            class="img-fluid hero-image"
                        >
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="about-me" class="about-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-5 text-center">
                    <div class="about-image-wrapper">
                        <img
                            src="/images/statics/livre.png"
                            alt="Présentation de Miftah Arabi"
                            class="img-fluid about-image"
                        >
                    </div>
                </div>

                <div class="col-lg-7">
                    <span class="section-subtitle">À propos</span>
                    <h2 class="section-title mt-2">À propos de Miftah Arabi</h2>

                    <p class="section-text mt-4">
                        Miftah Arabi est une plateforme pensée pour les francophones qui souhaitent apprendre
                        l'arabe de manière simple, progressive et motivante.
                    </p>

                    <p class="section-text">
                        Le projet s'adresse aux débutants comme aux apprenants plus avancés, avec des contenus
                        organisés par catégories, niveaux et thématiques.
                    </p>

                    <p class="section-text">
                        L'objectif est de proposer une approche claire et pédagogique, en s'appuyant sur des leçons,
                        des ressources utiles et des contenus accessibles depuis plusieurs supports.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="lessons-section">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-subtitle">Découvrir</span>
                <h2 class="section-title mt-2">Les dernières leçons</h2>
            </div>

            <div class="row g-4">
                {% for lesson in lessons %}
                    <div class="col-md-6 col-xl-4">
                        <article class="card lesson-card h-100">
                            {% if lesson.image %}
                                <img
                                    class="card-img-top lesson-card-image"
                                    src="{{ vich_uploader_asset(lesson, 'imageFile') | imagine_filter('visitor_lesson_thumb') }}"
                                    alt="{{ lesson.title }}"
                                >
                            {% else %}
                                <img
                                    class="card-img-top lesson-card-image"
                                    src="/images/statics/default-lesson-image.png"
                                    alt="{{ lesson.title }}"
                                >
                            {% endif %}

                            <div class="card-body d-flex flex-column">
                                <h3 class="lesson-card-title">{{ lesson.title|u.truncate(80, '...') }}</h3>

                                <div class="lesson-meta mt-3">
                                    <p class="mb-2">
                                        <strong>Catégorie :</strong>
                                        <span class="badge badge-category">{{ lesson.category.name }}</span>
                                    </p>

                                    <p class="mb-2">
                                        <strong>Niveau :</strong>
                                        <span class="badge badge-level">
                                            {% if lesson.level == 'debutant' %}
                                                Débutant
                                            {% elseif lesson.level == 'intermediaire' %}
                                                Intermédiaire
                                            {% elseif lesson.level == 'avance' %}
                                                Avancé
                                            {% else %}
                                                {{ lesson.level }}
                                            {% endif %}
                                        </span>
                                    </p>

                                    {% if lesson.tags is not empty %}
                                        <p class="mb-2">
                                            <strong>Tags :</strong>
                                            {% for tag in lesson.tags %}
                                                <span class="badge badge-tag">{{ tag.name }}</span>
                                            {% endfor %}
                                        </p>
                                    {% endif %}
                                </div>

                                <p class="lesson-date mt-2">
                                    Publié le {{ lesson.publishedAt|date('d/m/Y') }}
                                </p>

                                <div class="mt-auto pt-3">
                                    <a href="{{ path('app_visitor_lesson_show', {'id': lesson.id, 'slug': lesson.slug}) }}" class="btn btn-primary btn-ma">
                                        Lire la leçon
                                    </a>
                                </div>
                            </div>
                        </article>
                    </div>
                {% else %}
                    <div class="col-12">
                        <p class="text-center">Aucune leçon publiée pour le moment.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="container text-center">
            <span class="section-subtitle">Contact</span>
            <h2 class="section-title mt-2">Une question ?</h2>

            <p class="section-text cta-text mt-4">
                Vous pouvez me contacter pour toute question concernant les cours, les ressources
                ou l'apprentissage de l'arabe.
            </p>

            <a href="{{ path('app_visitor_contact_index') }}" class="btn btn-primary btn-ma mt-3">
                Contactez-moi
            </a>
        </div>
    </section>

{% endblock %}