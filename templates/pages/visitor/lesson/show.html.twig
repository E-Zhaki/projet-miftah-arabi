{% extends 'themes/base_visitor.html.twig' %}

{% block title %}{{ lesson.title }} | Miftah Arabi{% endblock %}

{% block description %}{{ lesson.description }}{% endblock %}

{% block keywords %}{{ lesson.keywords }}{% endblock %}

{% block main %}
    <section class="page-banner">
        <div class="container text-center">
            <span class="section-subtitle section-subtitle-light">{{ lesson.category.name }}</span>
            <h1 class="page-banner-title mt-2">{{ lesson.title }}</h1>
        </div>
    </section>

    <section class="lesson-show-section">
        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-lg-9">
                    <div class="lesson-show-card p-4 p-lg-5">

                        <div class="d-flex flex-wrap gap-2 mb-4">
                            <span class="badge badge-category">{{ lesson.category.name }}</span>
                            <span class="badge badge-level">
                                {% if lesson.level == 'debutant' %}
                                    Débutant
                                {% elseif lesson.level == 'intermediaire' %}
                                    Intermédiaire
                                {% elseif lesson.level == 'avance' %}
                                    Avancé
                                {% else %}
                                    {{ lesson.level }}
                                {% endif %}
                            </span>
                            {% for tag in lesson.tags %}
                                <span class="badge badge-tag">{{ tag.name }}</span>
                            {% endfor %}
                        </div>

                        <p class="section-text mb-4">{{ lesson.description }}</p>

                        {% if lesson.image %}
                            <div class="mb-4 text-center">
                                <img
                                    src="{{ vich_uploader_asset(lesson, 'imageFile') | imagine_filter('visitor_lesson_thumb') }}"
                                    alt="{{ lesson.title }}"
                                    class="img-fluid rounded-3"
                                    style="max-height: 420px; object-fit: cover; width: 100%;"
                                >
                            </div>
                        {% endif %}

                        <div class="lesson-content mt-4">
                            {{ lesson.content|raw }}
                        </div>

                        <p class="lesson-date mt-5">
                            Publié le {{ lesson.publishedAt|date('d/m/Y') }}
                        </p>

                        <div class="mt-4">
                            <a href="{{ path('app_visitor_lesson_index') }}" class="btn btn-outline-primary btn-ma-outline">
                                ← Retour aux leçons
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}