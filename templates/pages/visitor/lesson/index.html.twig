{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Leçons d'arabe | Miftah Arabi{% endblock %}

{% block description %}
Accédez aux leçons d'arabe de Miftah Arabi : alphabet, lecture, vocabulaire et bases de l'arabe littéraire pour débutants et intermédiaires.
{% endblock %}

{% block keywords %}
leçons arabe, cours d'arabe, arabe littéraire, apprendre l'arabe, alphabet arabe, Miftah Arabi
{% endblock %}

{% block knp_paginator %}
    {{ knp_pagination_rel_links(lessons) }}
{% endblock %}

{% block main %}
    {% include 'components/visitor/_header_visitor.html.twig' with {'h1': "Liste des leçons"} %}

    <div class="container my-5">

        {# FILTRES #}
        <div class="row text-center">

            {# Catégories #}
            <div class="col-md-4">
                <div class="dropdown my-2">
                    <a class="btn btn-secondary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Les catégories
                    </a>

                    <ul class="dropdown-menu">
                        {% if categories is not empty %}
                            {% for category in categories %}
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_visitor_lesson_filter_by_category', {'id': category.id, 'slug': category.slug}) }}">
                                        {{ category.name }} ({{ category.lessons|length }} leçon{{ category.lessons|length > 1 ? 's' : '' }})
                                    </a>
                                </li>
                            {% endfor %}
                        {% else %}
                            <li><a class="dropdown-item" href="#">Aucune catégorie</a></li>
                        {% endif %}
                    </ul>
                </div>
            </div>

            {# Tags #}
            <div class="col-md-4">
                <div class="dropdown my-2">
                    <a class="btn btn-secondary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Les tags
                    </a>

                    <ul class="dropdown-menu">
                        {% if tags is not empty %}
                            {% for tag in tags %}
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_visitor_lesson_filter_by_tag', {'id': tag.id, 'slug': tag.slug}) }}">
                                        {{ tag.name }} ({{ tag.lessons|length }} leçon{{ tag.lessons|length > 1 ? 's' : '' }})
                                    </a>
                                </li>
                            {% endfor %}
                        {% else %}
                            <li><a class="dropdown-item" href="#">Aucun tag</a></li>
                        {% endif %}
                    </ul>
                </div>
            </div>

            {# Niveaux #}
            <div class="col-md-4">
                <div class="dropdown my-2">
                    <a class="btn btn-secondary dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Les niveaux
                    </a>

                    <ul class="dropdown-menu">
                        {% if levels is not empty %}
                            {% for label, value in levels %}
                                <li>
                                    <a class="dropdown-item" href="{{ path('app_visitor_lesson_filter_by_level', {'level': value}) }}">
                                        {{ label }}
                                    </a>
                                </li>
                            {% endfor %}
                        {% else %}
                            <li><a class="dropdown-item" href="#">Aucun niveau</a></li>
                        {% endif %}
                    </ul>
                </div>
            </div>

        </div>

        {# LISTE DES LEÇONS #}
        <div class="row">
            <div class="col-md-12 col-lg-8 mx-auto">

                {% for lesson in lessons %}
                    <div class="card shadow my-5">
                        <div class="row g-0">

                            <div class="col-md-4">
                                {% if lesson.image %}
                                    <img class="w-100 h-100 rounded-start"
                                         src="{{ vich_uploader_asset(lesson, 'imageFile') | imagine_filter('visitor_lesson_thumb') }}"
                                         alt="{{ lesson.title }}">
                                {% else %}
                                    <img class="w-100 h-100"
                                         src="/images/statics/default-lesson-image.png"
                                         alt="{{ lesson.title }}">
                                {% endif %}
                            </div>

                            <div class="col-md-8">
                                <div class="card-body">

                                    <h5 class="card-title">
                                        {{ lesson.title|u.truncate(80, '...') }}
                                    </h5>

                                    <p class="card-text">
                                        Catégorie :
                                        <span class="badge text-bg-info">
                                            {{ lesson.category.name }}
                                        </span>
                                    </p>

                                    {# Niveau #}
                                    <p class="card-text">
                                        Niveau :
                                        <span class="badge text-bg-warning">
                                            {% if lesson.level == 'debutant' %}
                                                Débutant
                                            {% elseif lesson.level == 'intermediaire' %}
                                                Intermédiaire
                                            {% elseif lesson.level == 'avance' %}
                                                Avancé
                                            {% else %}
                                                {{ lesson.level }}
                                            {% endif %}
                                        </span>
                                    </p>

                                    {% if lesson.tags is not empty %}
                                        <p class="card-text">
                                            Tags :
                                            {% for tag in lesson.tags %}
                                                <span class="badge text-bg-secondary">
                                                    {{ tag.name }}
                                                </span>
                                            {% endfor %}
                                        </p>
                                    {% endif %}

                                    <p class="card-text">
                                        <small class="text-body-secondary">
                                            Publié le {{ lesson.publishedAt|date('d/m/Y à H:i') }}
                                        </small>
                                    </p>

                                    <a href="#" class="btn btn-primary shadow">
                                        Lire la leçon
                                    </a>

                                </div>
                            </div>

                        </div>
                    </div>
                {% else %}
                    <p class="text-center">Aucune leçon disponible.</p>
                {% endfor %}

                {# Pagination #}
                <div class="d-flex justify-content-center align-items-center">
                    {{ knp_pagination_render(lessons) }}
                </div>

            </div>
        </div>

    </div>
{% endblock %}