{% extends 'themes/base_visitor.html.twig' %}

{% block title %}Leçons d'arabe | Miftah Arabi{% endblock %}

{% block description %}
Accédez aux leçons d'arabe de Miftah Arabi : alphabet, lecture, vocabulaire et bases de l'arabe littéraire pour débutants et intermédiaires.
{% endblock %}

{% block keywords %}
leçons arabe, cours d'arabe, arabe littéraire, apprendre l'arabe, alphabet arabe, Miftah Arabi
{% endblock %}

{% block knp_paginator %}
    {{ knp_pagination_rel_links(lessons) }}
{% endblock %}

{% block main %}
    <section class="page-banner">
        <div class="container text-center">
            <span class="section-subtitle section-subtitle-light">Leçons</span>
            <h1 class="page-banner-title mt-2">Explorez les leçons</h1>
        </div>
    </section>

    <section class="lesson-list-section">
        <div class="container">

            <div class="lesson-filters-wrapper mb-5">
                <div class="row g-3 justify-content-center">

                    <div class="col-md-4">
                        <div class="dropdown">
                            <button class="btn btn-outline-primary btn-ma-outline dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Les catégories
                            </button>

                            <ul class="dropdown-menu w-100">
                                {% if categories is not empty %}
                                    {% for category in categories %}
                                        <li>
                                            <a class="dropdown-item" href="{{ path('app_visitor_lesson_filter_by_category', {'id': category.id, 'slug': category.slug}) }}">
                                                {{ category.name }} ({{ category.lessons|length }} leçon{{ category.lessons|length > 1 ? 's' : '' }})
                                            </a>
                                        </li>
                                    {% endfor %}
                                {% else %}
                                    <li><span class="dropdown-item">Aucune catégorie</span></li>
                                {% endif %}
                            </ul>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="dropdown">
                            <button class="btn btn-outline-primary btn-ma-outline dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Les tags
                            </button>

                            <ul class="dropdown-menu w-100">
                                {% if tags is not empty %}
                                    {% for tag in tags %}
                                        <li>
                                            <a class="dropdown-item" href="{{ path('app_visitor_lesson_filter_by_tag', {'id': tag.id, 'slug': tag.slug}) }}">
                                                {{ tag.name }} ({{ tag.lessons|length }} leçon{{ tag.lessons|length > 1 ? 's' : '' }})
                                            </a>
                                        </li>
                                    {% endfor %}
                                {% else %}
                                    <li><span class="dropdown-item">Aucun tag</span></li>
                                {% endif %}
                            </ul>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="dropdown">
                            <button class="btn btn-outline-primary btn-ma-outline dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Les niveaux
                            </button>

                            <ul class="dropdown-menu w-100">
                                {% if levels is not empty %}
                                    {% for label, value in levels %}
                                        <li>
                                            <a class="dropdown-item" href="{{ path('app_visitor_lesson_filter_by_level', {'level': value}) }}">
                                                {{ label }}
                                            </a>
                                        </li>
                                    {% endfor %}
                                {% else %}
                                    <li><span class="dropdown-item">Aucun niveau</span></li>
                                {% endif %}
                            </ul>
                        </div>
                    </div>

                </div>
            </div>

            <div class="row g-4">
                {% for lesson in lessons %}
                    <div class="col-12">
                        <article class="card lesson-list-card">
                            <div class="row g-0 align-items-stretch">

                                <div class="col-md-4">
                                    {% if lesson.image %}
                                        <img
                                            class="lesson-list-image"
                                            src="{{ vich_uploader_asset(lesson, 'imageFile') | imagine_filter('visitor_lesson_thumb') }}"
                                            alt="{{ lesson.title }}"
                                        >
                                    {% else %}
                                        <img
                                            class="lesson-list-image"
                                            src="/images/statics/default-lesson-image.png"
                                            alt="{{ lesson.title }}"
                                        >
                                    {% endif %}
                                </div>

                                <div class="col-md-8">
                                    <div class="card-body d-flex flex-column h-100">

                                        <h2 class="lesson-list-title">
                                            {{ lesson.title|u.truncate(80, '...') }}
                                        </h2>

                                        <div class="lesson-meta mt-3">
                                            <p class="mb-2">
                                                <strong>Catégorie :</strong>
                                                <span class="badge badge-category">
                                                    {{ lesson.category.name }}
                                                </span>
                                            </p>

                                            <p class="mb-2">
                                                <strong>Niveau :</strong>
                                                <span class="badge badge-level">
                                                    {% if lesson.level == 'debutant' %}
                                                        Débutant
                                                    {% elseif lesson.level == 'intermediaire' %}
                                                        Intermédiaire
                                                    {% elseif lesson.level == 'avance' %}
                                                        Avancé
                                                    {% else %}
                                                        {{ lesson.level }}
                                                    {% endif %}
                                                </span>
                                            </p>

                                            {% if lesson.tags is not empty %}
                                                <p class="mb-2">
                                                    <strong>Tags :</strong>
                                                    {% for tag in lesson.tags %}
                                                        <span class="badge badge-tag">{{ tag.name }}</span>
                                                    {% endfor %}
                                                </p>
                                            {% endif %}
                                        </div>

                                        <p class="lesson-date mt-2">
                                            Publié le {{ lesson.publishedAt|date('d/m/Y à H:i') }}
                                        </p>

                                        <div class="mt-auto pt-3">
                                            <a href="{{ path('app_visitor_lesson_show', {'id': lesson.id, 'slug': lesson.slug}) }}" class="btn btn-primary btn-ma">
                                                Lire la leçon
                                            </a>
                                        </div>

                                    </div>
                                </div>

                            </div>
                        </article>
                    </div>
                {% else %}
                    <div class="col-12">
                        <p class="text-center">Aucune leçon disponible.</p>
                    </div>
                {% endfor %}
            </div>

            <div class="pagination-wrapper mt-5 d-flex justify-content-center align-items-center">
                {{ knp_pagination_render(lessons) }}
            </div>

        </div>
    </section>
{% endblock %}