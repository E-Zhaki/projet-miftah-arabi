{% extends "themes/base_admin.html.twig" %}

{% block title %}Lire l'article-{{ lesson.id }}: {{lesson.title}}{% endblock %}

{% block description %}{{lesson.description}}{% endblock %}

{% block main %}

  
    
    <div class="container">
        <div class="text-center">
            {% if lesson.image %}
                <img
                    class="img-fluid"
                    src="{{ vich_uploader_asset(lesson, 'imageFile') }}"
                    alt="{{ lesson.title }}"
                    style="width: 100%; max-width: 720px; max-height: 420px; object-fit: cover; border-radius: 18px; display: inline-block;"
                >
            {% endif %}

            <h1 class="text-center my-3 display-6">{{lesson.title}}</h1>

            <div class="my-3">
                <small>Niveau {{lesson.level}}</small> <br>
                <small>Créé le {{lesson.createdAt|format_date}}</small> <br>
                <small>Modifié le {{lesson.updatedAt|format_date}}</small> <br>
                {% if lesson.isPublished %}
                <small>Publié le {{lesson.publishedAt|format_date}}</small> <br>
                {% endif %}
            </div>
        </div>

        <div class="my-5">

            <p>La catégories: <span class="badge text-bg-primary">{{lesson.category.name}}</span> </p>

            {% if lesson.tags is not empty %}
                <p>
                    Les tags: 
                    {% for tag in lesson.tags %}
                        <span class="badge text-bg-secondary">{{tag.name}}</span> 
                    {% endfor %}
                </p>
            {% endif %}
            
            

            {{lesson.content|raw}}
        </div>
    </div>

{% endblock %}

