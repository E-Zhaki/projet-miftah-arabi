<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>Inscription | Miftah Arabi</title>

        {# SEO #}
        <meta name="robots" content="index, follow">
        <meta name="description" content="Inscription sur Miftah Arabi, la plateforme pour apprendre l'arabe de manière simple, progressive et accessible.">
        <meta name="keywords" content="apprendre l'arabe, arabe littéraire, cours d'arabe, plateforme arabe, Miftah Arabi, débutant, francophone">
        <meta name="author" content="Zhaki El Ouarroudi">
        <meta name="publisher" content="Miftah Arabi">

        <meta name="theme-color" content="#c49b66">

        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="shortcut icon" href="/favicon.ico">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <meta name="apple-mobile-web-app-title" content="MyWebSite">
        <link rel="manifest" href="/site.webmanifest">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body class="ma-auth-bg ma-body ma-auth-body">
        <main>
            <div class="container">
                <div class="row align-items-center g-5 py-4">

                    {# Visuel #}
                    <div class="col-lg-6 d-none d-lg-flex justify-content-center align-items-center">
                        <img
                            src="/images/statics/inscription-miftah-arabi.svg"
                            alt="Illustration inscription Miftah Arabi"
                            class="img-fluid rounded-4 shadow-lg"
                        >
                    </div>

                    {# Formulaire #}
                    <div class="col-lg-6 d-flex justify-content-center">
                        <div class="ma-auth-card">

                            <h1 class="ma-auth-title">Inscription</h1>

                            {% for flash_error in app.flashes('verify_email_error') %}
                                <div class="alert alert-danger mb-3" role="alert">{{ flash_error }}</div>
                            {% endfor %}

                            {{ form_start(registrationForm, {'attr': {'class': 'ma-auth-form'}}) }}

                                <div class="row">
                                    <div class="col-sm-6 mb-3">
                                        <label for="registration_form_firstName">Prénom</label>
                                        <div class="text-danger" style="font-size:0.8rem;">{{ form_errors(registrationForm.firstName) }}</div>
                                        {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-control', 'autofocus': 'autofocus'}}) }}
                                    </div>
                                    <div class="col-sm-6 mb-3">
                                        <label for="registration_form_lastName">Nom</label>
                                        <div class="text-danger" style="font-size:0.8rem;">{{ form_errors(registrationForm.lastName) }}</div>
                                        {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-control'}}) }}
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="registration_form_email">Email</label>
                                    <div class="text-danger" style="font-size:0.8rem;">{{ form_errors(registrationForm.email) }}</div>
                                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                                </div>

                                <div class="mb-3">
                                    <label for="registration_form_password_first">Mot de passe</label>
                                    <div class="text-danger" style="font-size:0.8rem;">{{ form_errors(registrationForm.password.first) }}</div>
                                    {{ form_widget(registrationForm.password.first, {'attr': {'class': 'form-control', 'placeholder': 'Au moins 12 caractères'}}) }}
                                    <p class="ma-auth-hint"><i class="fa-solid fa-circle-exclamation"></i> Au moins une lettre minuscule et majuscule, un chiffre et un caractère spécial.</p>
                                </div>

                                <div class="mb-3">
                                    <label for="registration_form_password_second">Confirmation du mot de passe</label>
                                    <div class="text-danger" style="font-size:0.8rem;">{{ form_errors(registrationForm.password.second) }}</div>
                                    {{ form_widget(registrationForm.password.second, {'attr': {'class': 'form-control'}}) }}
                                </div>

                                <div class="mb-4">
                                    <div class="form-check">
                                        <div class="text-danger" style="font-size:0.8rem;">{{ form_errors(registrationForm.agreeTerms) }}</div>
                                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                                        <label class="form-check-label" for="registration_form_agreeTerms">
                                            Lire et accepter <a href="{{ path('app_visitor_terms_of_service') }}" target="_blank">les conditions générales d'utilisation</a>
                                        </label>
                                    </div>
                                </div>

                                <input type="submit" formnovalidate class="btn btn-primary w-100" value="S'inscrire">

                            {{ form_end(registrationForm) }}

                            <div class="text-center mt-4">
                                <p class="mb-1" style="font-size:0.9rem;">Déjà un compte ? <a href="{{ path('app_login') }}">Connectez-vous</a></p>
                                <a href="{{ path('app_visitor_welcome') }}" style="font-size:0.85rem;">Retour à l'accueil</a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </main>
    </body>
</html>
