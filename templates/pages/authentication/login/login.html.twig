<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>Connexion | Miftah Arabi</title>

        {# SEO #}
        <meta name="robots" content="index, follow">
        <meta name="description" content="Connectez-vous sur Miftah Arabi, la plateforme pour apprendre l'arabe de manière simple, progressive et accessible.">
        <meta name="keywords" content="apprendre l'arabe, arabe littéraire, cours d'arabe, plateforme arabe, Miftah Arabi, débutant, francophone">
        <meta name="author" content="Zhaki El Ouarroudi">
        <meta name="publisher" content="Miftah Arabi">

        <meta name="theme-color" content="#c49b66">

        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="shortcut icon" href="/favicon.ico">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <meta name="apple-mobile-web-app-title" content="MyWebSite">
        <link rel="manifest" href="/site.webmanifest">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body class="ma-auth-bg ma-body ma-auth-body">
        <main>
            <div class="container">
                <div class="row align-items-center g-5 py-4">

                    {# Visuel #}
                    <div class="col-lg-6 d-none d-lg-flex justify-content-center align-items-center">
                        <img
                            src="/images/statics/connexion-miftah-arabi.svg"
                            alt="Illustration connexion Miftah Arabi"
                            class="img-fluid rounded-4 shadow-lg"
                        >
                    </div>

                    {# Formulaire #}
                    <div class="col-lg-6 d-flex justify-content-center">
                        <div class="ma-auth-card">

                            <h1 class="ma-auth-title">Connexion</h1>

                            <form method="post" class="ma-auth-form">
                                {% if error %}
                                    <div class="alert alert-danger mb-3">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                                {% endif %}

                                {% include 'components/_alert.html.twig' %}

                                {% if app.user %}
                                    <div class="mb-3">
                                        Connecté en tant que {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Se déconnecter</a>
                                    </div>
                                {% endif %}

                                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                                <div class="mb-3">
                                    <label for="inputEmail">Email</label>
                                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
                                </div>

                                <div class="mb-3">
                                    <label for="inputPassword">Mot de passe</label>
                                    <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>
                                </div>

                                <div class="mb-4">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                                            <label class="form-check-label" for="rememberMe">Se souvenir de moi</label>
                                        </div>
                                        <a href="{{ path('app_forgot_password_request') }}" style="font-size:0.85rem;">Mot de passe oublié ?</a>
                                    </div>
                                </div>

                                <button formnovalidate class="btn btn-primary w-100" type="submit">Se connecter</button>
                            </form>

                            <div class="text-center mt-4">
                                <p class="mb-1" style="font-size:0.9rem;">Pas encore de compte ? <a href="{{ path('app_register') }}">Inscrivez-vous</a></p>
                                <a href="{{ path('app_visitor_welcome') }}" style="font-size:0.85rem;">Retour à l'accueil</a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </main>
    </body>
</html>
